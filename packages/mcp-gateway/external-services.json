{
    "externalServices": {
        "playwright": {
            "spawn": {
                "command": "node",
                "args": [
                    "./cli.js",
                    "--host",
                    "localhost",
                    "--port",
                    "8931",
                    "--allowed-hosts",
                    "*"
                ],
                "cwd": "../mcp-playwright",
                "env": {},
                "shell": false
            },
            "upstream": {
                "baseUrl": "http://localhost:8931",
                "path": "/mcp"
            },
            "ready": {
                "type": "tcp",
                "host": "localhost",
                "port": 8931,
                "timeoutMs": 30000
            }
        },
        "context7": {
            "spawn": {
                "command": "node",
                "args": [
                    "dist/index.js",
                    "--transport",
                    "http",
                    "--port",
                    "8950"
                ],
                "cwd": "../mcp-context7/packages/mcp",
                "env": {},
                "shell": false
            },
            "upstream": {
                "baseUrl": "http://127.0.0.1:8950",
                "path": "/mcp"
            },
            "ready": {
                "type": "tcp",
                "host": "127.0.0.1",
                "port": 8950,
                "timeoutMs": 60000
            }
        },
        "browser-tools-server": {
            "spawn": {
                "command": "node",
                "args": ["dist/browser-connector.js"],
                "cwd": "../mcp-browser-tools-server",
                "env": {
                    "PORT": "3025"
                },
                "shell": false
            },
            "upstream": {
                "baseUrl": "http://127.0.0.1:3025",
                "path": "/mcp"
            },
            "ready": {
                "type": "tcp",
                "host": "127.0.0.1",
                "port": 3025,
                "timeoutMs": 30000
            }
        },
        "browser-tools": {
            "spawn": {
                "command": "node",
                "args": [
                    "dist/mcp-server.js",
                    "--transport",
                    "http",
                    "--port",
                    "8952"
                ],
                "cwd": "../mcp-browser-tools",
                "env": {},
                "shell": false
            },
            "upstream": {
                "baseUrl": "http://127.0.0.1:8952",
                "path": "/mcp"
            },
            "ready": {
                "type": "tcp",
                "host": "127.0.0.1",
                "port": 8952,
                "timeoutMs": 30000
            }
        },
        "probe-kit": {
            "spawn": {
                "command": "node",
                "args": [
                    "build/index.js",
                    "--transport",
                    "http",
                    "--port",
                    "8960"
                ],
                "cwd": "../mcp-probe-kit",
                "env": {},
                "shell": false
            },
            "upstream": {
                "baseUrl": "http://127.0.0.1:8960",
                "path": "/mcp"
            },
            "ready": {
                "type": "tcp",
                "host": "127.0.0.1",
                "port": 8960,
                "timeoutMs": 60000
            }
        }
    }
}
