{
    "externalServices": {
        "playwright": {
            "spawn": {
                "command": "node",
                "args": [
                    "./cli.js",
                    "--host",
                    "localhost",
                    "--port",
                    "8931",
                    "--allowed-hosts",
                    "*"
                ],
                "cwd": "../mcp-playwright",
                "env": {},
                "shell": false
            },
            "upstream": {
                "baseUrl": "http://localhost:8931",
                "path": "/mcp"
            },
            "ready": {
                "type": "tcp",
                "host": "localhost",
                "port": 8931,
                "timeoutMs": 30000
            }
        },
        "firecrawl": {
            "spawn": {
                "command": "node",
                "args": ["dist/index.js"],
                "cwd": "../mcp-firecrawl",
                "env": {
                    "HTTP_STREAMABLE_SERVER": "true",
                    "CLOUD_SERVICE": "true",
                    "PORT": "8940",
                    "HOST": "127.0.0.1"
                },
                "shell": false
            },
            "upstream": {
                "baseUrl": "http://127.0.0.1:8940",
                "path": "/mcp"
            },
            "ready": {
                "type": "tcp",
                "host": "127.0.0.1",
                "port": 8940,
                "timeoutMs": 60000
            }
        },
        "context7": {
            "spawn": {
                "command": "node",
                "args": [
                    "dist/index.js",
                    "--transport",
                    "http",
                    "--port",
                    "8950"
                ],
                "cwd": "../mcp-context7/packages/mcp",
                "env": {},
                "shell": false
            },
            "upstream": {
                "baseUrl": "http://127.0.0.1:8950",
                "path": "/mcp"
            },
            "ready": {
                "type": "tcp",
                "host": "127.0.0.1",
                "port": 8950,
                "timeoutMs": 60000
            }
        },
        "probe-kit": {
            "spawn": {
                "command": "node",
                "args": [
                    "build/index.js",
                    "--transport",
                    "http",
                    "--host",
                    "127.0.0.1",
                    "--port",
                    "8960"
                ],
                "cwd": "../mcp-probe-kit",
                "env": {
                    "MCP_PROBE_KIT_TRANSPORT": "http",
                    "MCP_PROBE_KIT_HOST": "127.0.0.1",
                    "MCP_PROBE_KIT_PORT": "8960"
                },
                "shell": false
            },
            "upstream": {
                "baseUrl": "http://127.0.0.1:8960",
                "path": "/mcp"
            },
            "ready": {
                "type": "tcp",
                "host": "127.0.0.1",
                "port": 8960,
                "timeoutMs": 60000
            }
        }
    }
}
